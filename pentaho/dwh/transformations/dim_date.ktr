    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>var month_name;
var month_names = ["", "January", "February", "March", "April", "May", "June", 
                   "July", "August", "September", "October", "November", "December"];
month_name = month_names[parseInt(month)];

var day_name;
var day_names = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"];
day_name = day_names[parseInt(day_of_week)];

var kuartal;
kuartal = "Q" + Math.ceil(parseInt(month) / 3);

var kuartal_angka;
kuartal_angka = Math.ceil(parseInt(month) / 3);

var kuartal_tahun;
kuartal_tahun = "Q" + Math.ceil(parseInt(month) / 3) + parseInt(year);

var sk_waktu;
sk_waktu = parseInt(date.toString().substring(0, 10).replace(/-/g, ""));

var sk_kuartal;
sk_kuartal = parseInt(year) * 10 + Math.ceil(parseInt(month) / 3);

var sk_tahun;
sk_tahun = parseInt(year);

var sk_bulan;
sk_bulan = parseInt(year) * 100 + parseInt(month);

var hari_dalam_tahun;
hari_dalam_tahun = Math.floor((new Date(parseInt(year), parseInt(month)-1, parseInt(day)) - new Date(parseInt(year), 0, 0)) / 86400000);

var hari_dalam_bulan;
hari_dalam_bulan = parseInt(day);

var hari_dalam_minggu;
hari_dalam_minggu = parseInt(day_of_week) + 1;

var is_weekend;
var dow = parseInt(day_of_week);
if (dow == 5 || dow == 6)
  is_weekend = "Y";
else
  is_weekend = "N";</jsScript_script>
      </jsScript>
    </jsScripts>
